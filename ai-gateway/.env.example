# 运行环境: development | staging | production
APP_ENV=development

# 服务监听
HOST=0.0.0.0
PORT=8000

# 管理接口 Bearer Token（务必使用强随机值，勿提交到版本库）
ADMIN_TOKEN=change-me-to-a-long-random-secret

# 模型路由与客户端配置（可挂载为只读卷）
MODELS_CONFIG_PATH=/app/config/models.yaml
CLIENTS_CONFIG_PATH=/app/config/clients.yaml

# Redis（可选；未设置则使用进程内限流与统计，不适合多副本）
REDIS_URL=

# 日志级别
LOG_LEVEL=INFO

# 上游默认超时（秒）
UPSTREAM_TIMEOUT_SECONDS=120

# 熔断：连续失败次数后暂停使用该密钥（秒）
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_OPEN_SECONDS=60
