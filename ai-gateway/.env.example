# 运行环境: development | staging | production
APP_ENV=development

# 服务监听
HOST=0.0.0.0
PORT=8000

# 管理接口 Bearer Token（务必使用强随机值，勿提交到版本库）
ADMIN_TOKEN=change-me-to-a-long-random-secret

# JWT 密钥（生产环境必须覆盖）
JWT_SECRET_KEY=change-me-jwt-secret-for-dev-only

# 模型路由与客户端配置
MODELS_CONFIG_PATH=config/models.yaml
CLIENTS_CONFIG_PATH=config/clients.yaml

# 数据库（开发默认 SQLite，生产建议使用 MySQL）
DATABASE_URL=sqlite+aiosqlite:///./data/platform.db
# DATABASE_URL=mysql+aiomysql://platform:platform@mysql:3306/platform
# MySQL 使用 aiomysql 时由 pool_recycle 回收连接（勿依赖 pool_pre_ping，见 session.py）

# Redis（限流、验证码、用量统计）
REDIS_URL=

# Chroma 向量库持久化目录
CHROMA_PERSIST_DIR=./data/chroma

# 数据集上传目录
DATASET_UPLOAD_DIR=./data/uploads

# 平台内部客户端密钥（需与 clients.yaml 中 platform-internal 一致）
PLATFORM_CLIENT_SECRET=sk-platform-internal

# 临时固定账号密码登录（true=仅允许下方手机号+密码，关闭验证码登录）
FIXED_LOGIN_ENABLED=true
FIXED_LOGIN_PHONE=13800138000
FIXED_LOGIN_PASSWORD=Porsche@2026

# SMS 开发模式（返回验证码到响应中，生产设为 false）
SMS_DEV_MODE=true
# SMS_SEND_LIMIT_PER_PHONE=5
# SMS_SEND_LIMIT_PER_IP=20

# 模拟支付（生产必须为 false；本地开发可设为 true）
BILLING_ALLOW_MOCK_PAYMENT=false

# /metrics 鉴权（默认使用 ADMIN_TOKEN；可单独设置 METRICS_TOKEN）
# METRICS_TOKEN=

# 反向代理后设为 true 才信任 X-Forwarded-For
TRUST_PROXY_HEADERS=false

# 实名认证：生产应设为 false 并对接 KYC
REAL_NAME_AUTO_VERIFY=true

# 日志级别
LOG_LEVEL=INFO

# 上游默认超时（秒）
UPSTREAM_TIMEOUT_SECONDS=120

# 熔断配置
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_OPEN_SECONDS=60

# ===== 国内大模型 API 密钥（逗号分隔多密钥） =====
QWEN_API_KEYS=
ERNIE_API_KEYS=
HUNYUAN_API_KEYS=
DOUBAO_API_KEYS=
# DeepSeek V4 Flash（平台模型 deepseek-v4-flash 必填，改 .env 后需重启 gateway）
DEEPSEEK_API_KEYS=sk-your-deepseek-api-key
GLM_API_KEYS=sk-your-glm-api-key
MOONSHOT_API_KEYS=
YI_API_KEYS=
